{
  "name": "umkm-conversational-intelligence",
  "version": "1.0.0",
  "description": "Production-ready conversational BI layer for UMKM with Gemini-powered NLU",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node src/server.mjs",
    "dev": "concurrently \"node --watch src/server.mjs\" \"cd agent && .venv/bin/uvicorn agent.main:app --port 8001 --reload\"",
    "backup": "node scripts/backup.mjs",
    "restore": "node scripts/restore.mjs",
    "test": "NODE_ENV=test node --test --test-concurrency=1",
    "check": "NODE_ENV=test node --test --test-concurrency=1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "chart.js": "^4.5.1",
    "gridstack": "^12.4.2",
    "pg": "^8.20.0",
    "pg-mem": "^3.0.14"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
